public class GlobalExceptionHandler {

    @ExceptionHandler(NoSuchElementException.class)

    public ResponseEntity<String> handleNotFound(

            NoSuchElementException ex){

        return ResponseEntity

                .status(HttpStatus.NOT_FOUND)

                .body("User not found");

    }

